#!/bin/sh

PREFIX="/usr/local"
HOST=""
JIT="OFF"
DIST=ON
CFLAGS=

# NetBSD
if [ "`uname`" = "NetBSD" ]; then
    PREFIX="/usr/pkg"
fi

# Check if JIT available.
case "`uname -m`" in
  x86*)
    JIT=ON
    ;;
  arm*)
    JIT=ON
    ;;
  aarch64*)
    JIT=ON
    ;;
  riscv*)
    JIT=ON
    ;;
  powerpc*)
    JIT=ON
    ;;
  ppc*)
    JIT=ON
    ;;
  mips*)
    JIT=ON
    ;;
  i86pc*)
    JIT=ON
    ;;
  *)
    ;;
esac

# OpenBSD prohibits JIT.
if [ "`uname`" = "OpenBSD" ]; then
  JIT="OFF";
fi

# Parse options.
for OPT in "${@}"; do
    case "$OPT" in
        -h | --help)
            echo "Help:"
            echo "  configure --prefix=[/usr/local] [--disable-shared] [--disable-jit]"
            echo ""
            echo "[Dear Package Maintainers!]"
            echo "Thank you for your hardworking."
            echo "==Build Dep=="
            echo "  Debian:  apt-get install cmake build-essential libx11-dev libxpm-dev libasound2-dev mesa-common-dev libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev gstreamer1.0-x zlib1g-dev libpng-dev libjpeg-dev libbz2-dev libwebp-dev libogg-dev libvorbis-dev libfreetype-dev"
            echo "  RedHat:  dnf install patch cmake gcc libX11-devel libXpm-devel alsa-lib-devel mesa-libGL-devel gstreamer1-devel gstreamer1-plugins-base-devel zlib-devel libpng-devel libjpeg-turbo-devel bzip2-devel libwebp-devel libogg-devel libvorbis-devel freetype-devel"
            echo "  Arch:    pacman -S --needed base-devel cmake libx11 libxpm alsa-lib mesa gstreamer gst-plugins-base zlib libpng libjpeg-turbo bzip2 libwebp libogg libvorbis freetype2"
            echo "  FreeBSD: pkg install cmake pkgconf png webp freetype2 libogg libvorbis xorgproto libX11 libXpm mesa-libs gstreamer1 gstreamer1-plugins"
            echo "  NetBSD:  pkgin install cmake pkg-config libX11 libXpm MesaLib png libwebp freetype2 libogg libvorbis"
            echo "  OpenBSD: pkg_add cmake libx11 libxpm mesa png libwebp freetype libogg libvorbis"
            exit 0
            ;;
        --prefix=*)
            PREFIX=${OPT#--prefix=}
            ;;
        --cflags=*)
            CFLAGS=${OPT#--cflags=}
            ;;
        --disable-shared)
            DIST=OFF
            ;;
        --enable-static)
            DIST=OFF
            ;;
        --static)
            DIST=OFF
            ;;
        --disable-jit)
            JIT=OFF
            ;;
    esac
done

# Inform.
if [ "$JIT" = "ON" ]; then
  echo "JIT-enabled configuration for arch=`uname -m`.";
fi

# Decide the directory for the documents and the example
case "`uname`" in
  *BSD)
    DOCS="share/doc/suika3"
    GAME="share/examples/suika3"
    ;;
  *)
    DOCS="share/doc/suika3"
    GAME="share/doc/suika3/examples"
    ;;
esac

# Run CMake.
if [ -f CMakeLists.txt ]; then
    CMAKELISTS=.
else
    CMAKELISTS=..
fi
cmake $CMAKELISTS \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=$PREFIX \
      -DCMAKE_C_FLAGS_RELEASE="$CFLAGS" \
      -DPLAYFIELD_ENABLE_JIT=$JIT \
      -DSUIKA_ENABLE_PACK=ON \
      -DSUIKA_ENABLE_I18N=ON \
      -DSUIKA_ENABLE_DIST=$DIST \
      -DSUIKA_DIR_DOCS=$DOCS \
      -DSUIKA_DIR_GAME=$GAME
