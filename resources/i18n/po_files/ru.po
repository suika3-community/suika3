msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Error: %s: %d: %s"
msgstr "Ошибка: %s: %d: %s"

msgid "Cannot open file \"%s\"."
msgstr "Невозможно открыть файл \"%s\"."

msgid "Cannot get the size of file \"%s\"."
msgstr "Невозможно получить размер файла \"%s\"."

msgid "Cannot read file \"%s\"."
msgstr "Невозможно прочитать файл \"%s\"."

msgid "In tag %s:%d: runtime error."
msgstr "В теге %s:%d: ошибка выполнения."

msgid "%s:%d: Tag \"%s\" not found."
msgstr "%s:%d: Тег \"%s\" не найден."

msgid "%s:%d: \"tag_%s\" is not a function."
msgstr "%s:%d: \"tag_%s\" не является функцией."

msgid "In tag %s:%d: Tag \"%s\" execution error."
msgstr "В теге %s:%d: Ошибка выполнения тега \"%s\"."

msgid "Cannot determine the file type for \"%s\"."
msgstr "Невозможно определить тип файла \"%s\"."

msgid "Cannot load an image \"%s\"."
msgstr "Не удаётся загрузить изображение \"%s\"."

msgid "Too many textures."
msgstr "Слишком много текстур."

msgid "Invalid font slot index."
msgstr "Недопустимый индекс слота шрифта."

msgid "Invalid sound stream index."
msgstr "Недопустимый индекс звукового потока."

msgid "Cannot make the save directory."
msgstr "Не удалось создать каталог сохранения."

msgid "Save data key too long."
msgstr "Ключ сохранённых данных слишком длинный."

msgid "Cannot open a save file."
msgstr "Не удалось открыть файл сохранения."

msgid "Cannot write to a save file."
msgstr "Не удалось записать в файл сохранения."

msgid "Cannot get the size of a save file."
msgstr "Не удалось получить размер файла сохранения."

msgid "Save file too large."
msgstr "Файл сохранения слишком большой."

msgid "Cannot read a save file."
msgstr "Не удалось прочитать файл сохранения."

msgid "String too long."
msgstr "Строка слишком длинная."

msgid "Invalid save data."
msgstr "Недопустимые данные сохранения."

msgid "Searching directory \"%s\"."
msgstr "Поиск в каталоге «%s»."

msgid "Skipping empty directory \"%s\"."
msgstr "Пропуск пустого каталога «%s»."

msgid "Adding file \"%s\"."
msgstr "Добавление файла «%s»."

msgid "Parameter is not set."
msgstr "Параметр не задан."

msgid "Unexpected parameter value for \"%s\"."
msgstr "Непредвиденное значение параметра для «%s»."

msgid "Parameter \"%s\" doesn't have the key \"%s\"."
msgstr "Параметр «%s» не содержит ключ «%s»."

msgid "Unexpected parameter value for \"%s.%s\"."
msgstr "Непредвиденное значение параметра для «%s.%s»."

msgid "Cannot deserialize function."
msgstr "Не удалось десериализовать функцию."

