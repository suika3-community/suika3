msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Error: %s: %d: %s"
msgstr "Fehler: %s: %d: %s"

msgid "Cannot open file \"%s\"."
msgstr "Datei \"%s\" kann nicht geöffnet werden."

msgid "Cannot get the size of file \"%s\"."
msgstr "Die Größe der Datei \"%s\" kann nicht ermittelt werden."

msgid "Cannot read file \"%s\"."
msgstr "Datei \"%s\" kann nicht gelesen werden."

msgid "In tag %s:%d: runtime error."
msgstr "In Tag %s:%d: Laufzeitfehler."

msgid "%s:%d: Tag \"%s\" not found."
msgstr "%s:%d: Tag \"%s\" wurde nicht gefunden."

msgid "%s:%d: \"tag_%s\" is not a function."
msgstr "%s:%d: \"tag_%s\" ist keine Funktion."

msgid "In tag %s:%d: Tag \"%s\" execution error."
msgstr "In Tag %s:%d: Ausführungsfehler im Tag \"%s\"."

msgid "Cannot determine the file type for \"%s\"."
msgstr "Der Dateityp von \"%s\" kann nicht bestimmt werden."

msgid "Cannot load an image \"%s\"."
msgstr "Das Bild \"%s\" kann nicht geladen werden."

msgid "Too many textures."
msgstr "Zu viele Texturen."

msgid "Invalid font slot index."
msgstr "Ungültiger Schriftart-Slot-Index."

msgid "Invalid sound stream index."
msgstr "Ungültiger Soundstream-Index."

msgid "Cannot make the save directory."
msgstr "Das Speicherverzeichnis kann nicht erstellt werden."

msgid "Save data key too long."
msgstr "Der Schlüssel der Spieldaten ist zu lang."

msgid "Cannot open a save file."
msgstr "Eine Speicherdatei kann nicht geöffnet werden."

msgid "Cannot write to a save file."
msgstr "In eine Speicherdatei kann nicht geschrieben werden."

msgid "Cannot get the size of a save file."
msgstr "Die Größe einer Speicherdatei kann nicht ermittelt werden."

msgid "Save file too large."
msgstr "Die Speicherdatei ist zu groß."

msgid "Cannot read a save file."
msgstr "Eine Speicherdatei kann nicht gelesen werden."

msgid "String too long."
msgstr "Zeichenkette zu lang."

msgid "Invalid save data."
msgstr "Ungültige Spieldaten."

msgid "Searching directory \"%s\"."
msgstr "Suche im Verzeichnis \"%s\"."

msgid "Skipping empty directory \"%s\"."
msgstr "Leeres Verzeichnis \"%s\" wird übersprungen."

msgid "Adding file \"%s\"."
msgstr "Datei \"%s\" wird hinzugefügt."

msgid "Parameter is not set."
msgstr "Parameter ist nicht gesetzt."

msgid "Unexpected parameter value for \"%s\"."
msgstr "Unerwarteter Parameterwert für \"%s\"."

msgid "Parameter \"%s\" doesn't have the key \"%s\"."
msgstr "Parameter \"%s\" hat keinen Schlüssel \"%s\"."

msgid "Unexpected parameter value for \"%s.%s\"."
msgstr "Unerwarteter Parameterwert für \"%s.%s\"."

msgid "Cannot deserialize function."
msgstr "Funktion kann nicht deserialisiert werden."

