msgid "Error: %s: %d: %s"
msgstr "Erreur : %s : %d : %s"

msgid "Cannot open file \"%s\"."
msgstr "Impossible d'ouvrir le fichier \"%s\"."

msgid "Cannot get the size of file \"%s\"."
msgstr "Impossible d'obtenir la taille du fichier \"%s\"."

msgid "Cannot read file \"%s\"."
msgstr "Impossible de lire le fichier \"%s\"."

msgid "In tag %s:%d: runtime error."
msgstr "Dans la balise %s : %d : erreur d'exécution."

msgid "%s:%d: Tag \"%s\" not found."
msgstr "%s : %d : Balise \"%s\" introuvable."

msgid "%s:%d: \"tag_%s\" is not a function."
msgstr "%s : %d : \"tag_%s\" n'est pas une fonction."

msgid "In tag %s:%d: Tag \"%s\" execution error."
msgstr "Dans la balise %s : %d : Erreur d'exécution de la balise \"%s\"."

msgid "Cannot determine the file type for \"%s\"."
msgstr "Impossible de déterminer le type du fichier  \"%s\"."

msgid "Cannot load an image \"%s\"."
msgstr "Impossible de charger l'image \"%s\"."

msgid "Too many textures."
msgstr "Trop de textures."

msgid "Invalid font slot index."
msgstr "Indice d'emplacement de police non valide."

msgid "Invalid sound stream index."
msgstr "Indice de flux sonore non valide."

msgid "Cannot make the save directory."
msgstr "Impossible de créer le répertoire de sauvegarde."

msgid "Save data key too long."
msgstr "La clé des données de sauvegarde est trop longue."

msgid "Cannot open a save file."
msgstr "Impossible d'ouvrir un fichier de sauvegarde."

msgid "Cannot write to a save file."
msgstr "Impossible d'écrire dans un fichier de sauvegarde."

msgid "Cannot get the size of a save file."
msgstr "Impossible d'obtenir la taille d'un fichier de sauvegarde."

msgid "Save file too large."
msgstr "Le fichier de sauvegarde est trop volumineux."

msgid "Cannot read a save file."
msgstr "Impossible de lire un fichier de sauvegarde."

msgid "String too long."
msgstr "Chaîne trop longue."

msgid "Invalid save data."
msgstr "Données de sauvegarde non valides."

msgid "Searching directory \"%s\"."
msgstr "Recherche dans le répertoire \"%s\"."

msgid "Skipping empty directory \"%s\"."
msgstr "Ignorer le répertoire vide \"%s\"."

msgid "Adding file \"%s\"."
msgstr "Ajout du fichier \"%s\"."

msgid "Parameter is not set."
msgstr "Le paramètre n'est pas défini."

msgid "Unexpected parameter value for \"%s\"."
msgstr "Valeur de paramètre inattendue pour \"%s\"."

msgid "Parameter \"%s\" doesn't have the key \"%s\"."
msgstr "Le paramètre \"%s\" n'a pas la clé \"%s\"."

msgid "Unexpected parameter value for \"%s.%s\"."
msgstr "Valeur de paramètre inattendue pour \"%s.%s\"."

msgid "Cannot deserialize function."
msgstr "Impossible de désérialiser la fonction."

