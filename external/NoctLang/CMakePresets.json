{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3, "minor": 22, "patch": 0
    },
    "configurePresets": [
        {
            "name":           "msdos",
            "displayName":    "MS-DOS",
            "generator":      "Ninja",
            "binaryDir":      "${sourceDir}/build-msdos",
            "toolchainFile":  "${sourceDir}/cmake/toolchains/openwatcom-dos4gw.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":          "Release",
                "NOCT_TARGET_DOS4G":         "ON",
                "NOCT_ENABLE_CLI":           "ON",
                "NOCT_ENABLE_JIT":           "ON",
                "NOCT_ENABLE_I18N":          "OFF",
                "NOCT_ENABLE_API":           "ON"
	    }
        }
    ],
    "buildPresets": [
        {
            "name": "msdos",
            "configurePreset": "msdos",
            "configuration": "Release"
        }
    ]
}
