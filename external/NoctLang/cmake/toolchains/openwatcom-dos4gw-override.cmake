set(CMAKE_C_LINK_EXECUTABLE
    "<CMAKE_C_COMPILER> <FLAGS> -bt=dos -l=dos4g -k32768 -fe=<TARGET> <OBJECTS> <LINK_LIBRARIES>"
    CACHE STRING "C link command" FORCE)

set(CMAKE_EXE_LINKER_FLAGS
    ""
    CACHE STRING "Executable linker flags" FORCE)

set(CMAKE_C_LINK_LIBRARY_FILE_FLAG "")
set(CMAKE_LINK_LIBRARY_FILE_FLAG "")
set(CMAKE_LINK_LIBRARY_FLAG "")

set(CMAKE_C_CREATE_STATIC_LIBRARY
    "wlib -q -b -n <TARGET> <OBJECTS>"
    CACHE STRING "C static library command" FORCE)

set(CMAKE_C_FLAGS_RELEASE "-bt=dos -s -ot -dNDEBUG")
