msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Error: %s: %d: %s"
msgstr "Σφάλμα: %s: %d: %s"

msgid "Cannot open file \"%s\"."
msgstr "Δεν είναι δυνατό το άνοιγμα του αρχείου \"%s\"."

msgid "Cannot get the size of file \"%s\"."
msgstr "Δεν είναι δυνατή η λήψη του μεγέθους του αρχείου \"%s\"."

msgid "Cannot read file \"%s\"."
msgstr "Δεν είναι δυνατή η ανάγνωση του αρχείου \"%s\"."

msgid "In tag %s:%d: runtime error."
msgstr "Στην ετικέτα %s:%d: σφάλμα χρόνου εκτέλεσης."

msgid "%s:%d: Tag \"%s\" not found."
msgstr "%s:%d: Η ετικέτα \"%s\" δεν βρέθηκε."

msgid "%s:%d: \"tag_%s\" is not a function."
msgstr "%s:%d: Το \"tag_%s\" δεν είναι συνάρτηση."

msgid "In tag %s:%d: Tag \"%s\" execution error."
msgstr "Στην ετικέτα %s:%d: Σφάλμα εκτέλεσης στην ετικέτα \"%s\"."

msgid "Cannot determine the file type for \"%s\"."
msgstr "Δεν είναι δυνατός ο προσδιορισμός του τύπου αρχείου για το \"%s\"."

msgid "Cannot load an image \"%s\"."
msgstr "Δεν είναι δυνατή η φόρτωση της εικόνας \"%s\"."

msgid "Too many textures."
msgstr "Πάρα πολλές υφές."

msgid "Invalid font slot index."
msgstr "Μη έγκυρος δείκτης υποδοχής γραμματοσειράς."

msgid "Invalid sound stream index."
msgstr "Μη έγκυρος δείκτης ροής ήχου."

msgid "Cannot make the save directory."
msgstr "Δεν είναι δυνατή η δημιουργία του καταλόγου αποθήκευσης."

msgid "Save data key too long."
msgstr "Το κλειδί των δεδομένων αποθήκευσης είναι πολύ μεγάλο."

msgid "Cannot open a save file."
msgstr "Δεν είναι δυνατό το άνοιγμα ενός αρχείου αποθήκευσης."

msgid "Cannot write to a save file."
msgstr "Δεν είναι δυνατή η εγγραφή σε ένα αρχείο αποθήκευσης."

msgid "Cannot get the size of a save file."
msgstr "Δεν είναι δυνατή η λήψη του μεγέθους ενός αρχείου αποθήκευσης."

msgid "Save file too large."
msgstr "Το αρχείο αποθήκευσης είναι πολύ μεγάλο."

msgid "Cannot read a save file."
msgstr "Δεν είναι δυνατή η ανάγνωση ενός αρχείου αποθήκευσης."

msgid "String too long."
msgstr "Η συμβολοσειρά είναι πολύ μεγάλη."

msgid "Invalid save data."
msgstr "Μη έγκυρα δεδομένα αποθήκευσης."

msgid "Searching directory \"%s\"."
msgstr "Αναζήτηση στον κατάλογο \"%s\"."

msgid "Skipping empty directory \"%s\"."
msgstr "Παράλειψη κενού καταλόγου \"%s\"."

msgid "Adding file \"%s\"."
msgstr "Προσθήκη αρχείου \"%s\"."

msgid "Parameter is not set."
msgstr "Η παράμετρος δεν έχει οριστεί."

msgid "Unexpected parameter value for \"%s\"."
msgstr "Μη αναμενόμενη τιμή παραμέτρου για \"%s\"."

msgid "Parameter \"%s\" doesn't have the key \"%s\"."
msgstr "Η παράμετρος \"%s\" δεν έχει το κλειδί \"%s\"."

msgid "Unexpected parameter value for \"%s.%s\"."
msgstr "Μη αναμενόμενη τιμή παραμέτρου για \"%s.%s\"."

msgid "Cannot deserialize function."
msgstr "Αδυναμία αποσειριοποίησης της συνάρτησης."

