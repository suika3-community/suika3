msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Error: %s: %d: %s"
msgstr "Errore: %s: %d: %s"

msgid "Cannot open file \"%s\"."
msgstr "Impossibile aprire il file \"%s\"."

msgid "Cannot get the size of file \"%s\"."
msgstr "Impossibile ottenere la dimensione del file \"%s\"."

msgid "Cannot read file \"%s\"."
msgstr "Impossibile leggere il file \"%s\"."

msgid "In tag %s:%d: runtime error."
msgstr "Nel tag %s:%d: errore di runtime."

msgid "%s:%d: Tag \"%s\" not found."
msgstr "%s:%d: Tag \"%s\" non trovato."

msgid "%s:%d: \"tag_%s\" is not a function."
msgstr "%s:%d: \"tag_%s\" non è una funzione."

msgid "In tag %s:%d: Tag \"%s\" execution error."
msgstr "Nel tag %s:%d: Errore di esecuzione del tag \"%s\"."

msgid "Cannot determine the file type for \"%s\"."
msgstr "Impossibile determinare il tipo di file per \"%s\"."

msgid "Cannot load an image \"%s\"."
msgstr "Impossibile caricare l'immagine \"%s\"."

msgid "Too many textures."
msgstr "Troppe texture."

msgid "Invalid font slot index."
msgstr "Indice di slot del font non valido."

msgid "Invalid sound stream index."
msgstr "Indice di stream audio non valido."

msgid "Cannot make the save directory."
msgstr "Impossibile creare la directory di salvataggio."

msgid "Save data key too long."
msgstr "La chiave dei dati di salvataggio è troppo lunga."

msgid "Cannot open a save file."
msgstr "Impossibile aprire un file di salvataggio."

msgid "Cannot write to a save file."
msgstr "Impossibile scrivere in un file di salvataggio."

msgid "Cannot get the size of a save file."
msgstr "Impossibile ottenere la dimensione di un file di salvataggio."

msgid "Save file too large."
msgstr "Il file di salvataggio è troppo grande."

msgid "Cannot read a save file."
msgstr "Impossibile leggere un file di salvataggio."

msgid "String too long."
msgstr "Stringa troppo lunga."

msgid "Invalid save data."
msgstr "Dati di salvataggio non validi."

msgid "Searching directory \"%s\"."
msgstr "Ricerca nella directory \"%s\"."

msgid "Skipping empty directory \"%s\"."
msgstr "Salto della directory vuota \"%s\"."

msgid "Adding file \"%s\"."
msgstr "Aggiunta del file \"%s\"."

msgid "Parameter is not set."
msgstr "Il parametro non è impostato."

msgid "Unexpected parameter value for \"%s\"."
msgstr "Valore del parametro imprevisto per \"%s\"."

msgid "Parameter \"%s\" doesn't have the key \"%s\"."
msgstr "Il parametro \"%s\" non ha la chiave \"%s\"."

msgid "Unexpected parameter value for \"%s.%s\"."
msgstr "Valore del parametro imprevisto per \"%s.%s\"."

msgid "Cannot deserialize function."
msgstr "Impossibile deserializzare la funzione."

