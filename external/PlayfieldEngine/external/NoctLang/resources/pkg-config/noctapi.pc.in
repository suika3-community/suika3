prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: Noct API
Description: Noct programming language standard API library
Version: @PROJECT_VERSION@
Cflags: -I${includedir}/noct
Libs: -L${libdir} -lnoctapi

Requires.private: noct
