msgstr "Индекс не является целым числом."

msgid "Not an array or a dictionary."
msgstr "Это не массив и не словарь."

msgid "Subscript not a string."
msgstr "Индекс не является строкой."

msgid "Value is not a string, an array, or a dictionary."
msgstr "Значение не является ни строкой, ни массивом, ни словарем."

msgid "Not a dictionary."
msgstr "Это не словарь."

msgid "Dictionary index out-of-range."
msgstr "Индекс словаря вне допустимого диапазона."

msgid "Symbol \"%s\" not found."
msgstr "Символ \"%s\" не найден."

msgid "%s(): Function arguments not match."
msgstr "%s(): Аргументы функции не совпадают."

msgid "Element %d is not an integer."
msgstr "Элемент %d не является целым числом."

msgid "Element %d is not a float."
msgstr "Элемент %d не является числом с плавающей точкой."

msgid "Element %d is not a string."
msgstr "Элемент %d не является строкой."

msgid "Element %d is not an array."
msgstr "Элемент %d не является массивом."

msgid "Element %d is not a dictionary."
msgstr "Элемент %d не является словарем."

msgid "Element %d is not a function."
msgstr "Элемент %d не является функцией."

msgid "Value for key %s is not an integer."
msgstr "Значение для ключа %s не является целым числом."

msgid "Value for key %s is not a float."
msgstr "Значение для ключа %s не является числом с плавающей точкой."

msgid "Value for key %s is not a string."
msgstr "Значение для ключа %s не является строкой."

msgid "Value for key %s is not an array."
msgstr "Значение для ключа %s не является массивом."

msgid "Value for key %s is not a dictionary."
msgstr "Значение для ключа %s не является словарем."

msgid "Value for key %s is not a function."
msgstr "Значение для ключа %s не является функцией."

msgid "Argument (%d: %s) not an integer."
msgstr "Аргумент (%d: %s) не является целым числом."

msgid "Argument (%d: %s) not a float."
msgstr "Аргумент (%d: %s) не является числом с плавающей точкой."

msgid "Argument (%d: %s) not a string."
msgstr "Аргумент (%d: %s) не является строкой."

msgid "Argument (%d: %s) is not an array."
msgstr "Аргумент (%d: %s) не является массивом."

msgid "Argument (%d: %s) is not a dictionary."
msgstr "Аргумент (%d: %s) не является словарем."

msgid "Not a function."
msgstr "Это не функция."

msgid "Empty array."
msgstr "Пустой массив."

msgid "Out of memory."
msgstr "Недостаточно памяти."

msgid "Too many pinned global variables."
msgstr "Слишком много закрепленных глобальных переменных."

msgid "Too many pinned local variables."
msgstr "Слишком много закрепленных локальных переменных."

msgid "Cannot open file %s.\n"
msgstr "Не удаётся открыть файл %s.\n"

msgid "Cannot read file %s.\n"
msgstr "Не удалось прочитать файл %s.\n"

msgid "Error: %s: %d: %s\n"
msgstr "Ошибка: %s: %d: %s\n"

msgid "Adding file %s\n"
msgstr "Добавление файла %s\n"

msgid "Cannot find %s.\n"
msgstr "Не удалось найти %s.\n"

msgid "Searching directory %s.\n"
msgstr "Поиск в каталоге %s.\n"

msgid "Skipping empty directory %s.\n"
msgstr "Пропуск пустого каталога %s.\n"

msgid "Unknown option %s.\n"
msgstr "Неизвестная опция %s.\n"

msgid "Specify a file.\n"
msgstr "Укажите файл.\n"

msgid "%s:%d: Error: %s\n"
msgstr "%s:%d: Ошибка: %s\n"

msgid "Out of memory.\n"
msgstr "Недостаточно памяти.\n"

msgid "Noct Programming Language\n"
msgstr "Язык программирования Noct\n"

msgid "Version %s\n"
msgstr "Версия %s\n"

msgid "Entering REPL mode.\n"
msgstr "Переход в режим REPL.\n"

msgid "JIT compilation is enabled. Starting the fast VM...\n"
msgstr "JIT-компиляция включена. Запуск быстрой виртуальной машины...\n"

msgid "Usage\n"
msgstr "Использование\n"

msgid "noct <vm-options> <files>          ... run a program\n"
msgstr "noct <vm-options> <files>          ... запуск программы\n"

msgid "noct --ansic <out-file> <in-files> ... convert to a C source file\n"
msgstr "noct --ansic <out-file> <in-files> ... преобразовать в исходный файл C\n"

msgid "noct --elisp <out-file> <in-files> ... convert to an Emacs Lisp source file\n"
msgstr "noct --elisp <out-file> <in-files> ... преобразовать в исходный файл Emacs Lisp\n"

msgid "--disable-jit        ... disable JIT\n"
msgstr "--disable-jit        ... отключить JIT\n"

msgid "--force-jit          ... equivalent to --jit-threshold=0\n"
msgstr "--force-jit          ... эквивалентно --jit-threshold=0\n"

msgid "--jit-threshold=N    ... call-count threshold for compilation\n"
msgstr "--jit-threshold=N    ... порог количества вызовов для компиляции\n"

msgid "--optimize-level=N   ... optimize level (0/1)\n"
msgstr "--optimize-level=N   ... уровень оптимизации (0/1)\n"

msgid "--gc-nursery-size=N  ... first GC space size in bytes\n"
msgstr "--gc-nursery-size=N  ... размер первой области GC в байтах\n"

msgid "--gc-graduate-size=N ... second GC space size in bytes\n"
msgstr "--gc-graduate-size=N ... размер второй области GC в байтах\n"

msgid "--gc-tenure-size=N   ... final GC space size in bytes\n"
msgstr "--gc-tenure-size=N   ... размер финальной области GC в байтах\n"

msgid "--gc-lop-threshold=N ... move objects larger than N-bytes to final GC space\n"
msgstr "--gc-lop-threshold=N ... перемещать объекты больше N байт в финальную область GC\n"

