msgid "syntax error"
msgstr "Синтаксическая ошибка."

msgid "%s: Out of memory while parsing."
msgstr "%s: Недостаточно памяти при разборе."

msgid "Too many functions."
msgstr "Слишком много функций."

msgid "continue appeared outside loop."
msgstr "Оператор continue использован вне цикла."

msgid "LHS is not a term or an array element."
msgstr "Левая часть не является ни выражением, ни элементом массива."

msgid "var is specified without a single symbol."
msgstr "var указан без единственного символа."

msgid "else-if block appeared without if block."
msgstr "Блок else-if появился без блока if."

msgid "else-if appeared after else."
msgstr "else-if появился после else."

msgid "else appeared after else."
msgstr "else использовано после else."

msgid "Exceeded the maximum argument count."
msgstr "Превышено максимальное количество аргументов."

