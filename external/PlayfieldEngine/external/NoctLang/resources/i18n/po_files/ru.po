msgstr "Слишком много анонимных функций."

msgid "Too many local variables."
msgstr "Слишком много локальных переменных."

msgid "Too many jumps."
msgstr "Слишком много переходов."

msgid "LIR: Out of memory error."
msgstr "LIR: Недостаточно памяти."

msgid "Failed to load bytecode data."
msgstr "Не удалось загрузить данные байткода."

msgid "Memory mapping failed."
msgstr "Ошибка отображения памяти."

msgid "Code too big."
msgstr "Код слишком большой."

msgid "Branch target not found."
msgstr "Цель перехода не найдена."

msgid "Failed to load bytecode."
msgstr "Не удалось загрузить байт-код."

