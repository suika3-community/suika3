            image: "system/message/msgbox.png",

            // メッセージボックスの位置
            x: 0,
            y: 520,

            // メッセージボックスのマージン(ピクセル)
            margin: {
                // 四方のマージン
                left:   200,
                top:    20,
                right:  200,
                bottom: 30,

                // 行間(文字の高さを含む1行の高さ)
                line: 40,

                // 文字と文字の間
                char: 0
            },

            // メッセージボックスのフォント
            font: {
                // フォント選択(1,2,3,4)
                select: 1,

                // フォントサイズ
                size: 36,

                // フォントの色
                r: 255,
                g: 255,
                b: 255,

                // フォントのふちどり
