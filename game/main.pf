// ウィンドウが作成されるときに呼ばれます
func setup() {
    // ウィンドウの設定を返します
    return {
        width:  1280,
        height: 720,
        title:  "My First Game"
    };
}

// ゲームが開始するときに呼ばれます
func start() {
    // 設定を記述します
    var config = {
        // ゲーム全般の設定
        game: {
            // タイトル
            //  - フォルダ名に使えない特殊文字を含めないでください
            title: "サンプルゲーム",

            // 画面のサイズ
            //  - 1280x720 あるいは 720x1280 が推奨です
            width:  1280,
            height: 720,

            // 言語設定
            //  - "":   システムの言語
            //  - "ja": 日本語に固定
            //  - "en": 英語に固定
            locale: "ja"
        },
        
        // フォントファイルの設定
        font: {
            // フォント1
            //  - デフォルトフォント
            //  - 文中で \f{1} で選択できる
            ttf1: "rounded-l-mplus-1c-bold.ttf",

            // フォント2
            //  - 文中で \f{2} で選択できる
            ttf2: "",

            // フォント3
            //  - 文中で \f{3} で選択できる
            ttf3: "",

            // フォント4
            //  - 文中で \f{4} で選択できる
            ttf4: ""
        },

        // メッセージボックスの設定
        msbox: {
