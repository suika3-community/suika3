                "",       // キャラ2番
                "",       // キャラ3番
                "",       // キャラ4番
                "",       // キャラ5番
                "",       // キャラ6番
                "",       // キャラ7番
                "",       // キャラ8番
                "",       // キャラ9番
                "",       // キャラ10番
                "",       // キャラ11番
                "",       // キャラ12番
                "",       // キャラ13番
                "",       // キャラ14番
                ""        // キャラ15番
            ]
        },

        // キャラクタ
        character: {
            // 発声キャラクタの自動フォーカスを行うか
            //  - false: しない
            //  - true:  する
            focus: false,

            // 目パチ
            eyeblink: {
                // 目パチの間隔(秒)
                interval: 4.0,

                // 目パチアニメの1フレームの秒数
                frame: 0.05
            },

            // 口パク
            lipsync: {
                // 口パクの1フレームの秒数
                frame: 0.06,

                // 口パクを何文字ごとに行うか
                chars: 3
            }
        },

        // ステージの設定
        stage: {
            // キャラクタの位置補正(下端マージン)
            ch_margin_bottom: 0,

            // キャラクタの位置補正(左端マージン)
            ch_margin_left: 0,

            // キャラクタの位置補正(右端マージン)
            ch_margin_right: 0
        },

        // 変数の別名
        variable: [
            {index:0, name:"選択肢1を読んだか"},
            {index:1, name:"選択肢2を読んだか"},
            {index:2, name:"選択肢2を読んだか"},
            {index:10000, name:"実績解除1"},
            {index:10001, name:"実績解除1"},
            {index:10002, name:"実績解除3"}
        ],

        // タップ時のキラキラエフェクト
        kirakira: {
            // キラキラエフェクトを使うか
            //  - false: 使わない
            //  - true:  使う
            enable: false,

            // キラキラエフェクトで加算合成を使うか
            //  - false: 通常合成
            //  - true:  加算合成
            add: false,

            // キラキラエフェクトの1フレームの時間(秒)
            frame: 0.333,

            // キラキラエフェクトのイメージ(1から16, 最大16まで)
            image: [
                "kira1.png",
                "kira2.png",
                "kira3.png",
                "kira4.png"
            ]
        },

        // 独自の絵文字
        //  - スクリプトで使う時は\e{絵文字名}と書く
        emoticon: [
            {name:"heart", image:"emoji/heart.png"},
            {name:"sweat", image:"emoji/sweat.png"}
        ],

        // テキスト読み上げ
        tts: {
            // テキスト読み上げを有効にする
            //  false: いいえ
            //  true:  はい
            enable: false
        },

        // リリースモード
        release_mode: {
            // Windows/Macでインストールアプリにするとき有効にする
            enable: false
        }
    };
}

