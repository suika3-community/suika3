                    // 幅
                    width: 0,

                    // フォントのふちどりの色
                    r: 255,
                    g: 255,
                    b: 255
                },

                // ルビのサイズ
                ruby: 10,

                // 縦書きを使うか
                //  - false: 横書き
                //  - true:  縦書き
                tategaki: false
            },

            // 文中でクリック待ちしたとき、既存文章を暗くするか(ディミング)
            dim: {
                // ディミングの有効
                //  - false:  暗くしない
                //  - true:   暗くする
                enable: false,

                // ディミングの色
                r: 0,
                g: 0,
                b: 0,

                // ディミングのふちどりの色
                outline: {
                    r: 0,
                    g: 0,
                    b: 0
                }
            },

            // 既読メッセージの色
            seen: {
                // 既読メッセージの色を変えるか
                //  - false: 変えない
                //  - true:  変える
                enable: false,

                // 既読メッセージの色
                r: 0,
                g: 0,
                b: 0,

                // ふちどりの色
                outline: {
                    r: 0,
                    g: 0,
                    b: 0
                }
            },

            // キャラクタ変更中にメッセージボックスを表示するか
            //  - false: 表示しない
            //  - true:  表示する
            show_on_ch: true,

            // 背景変更中にメッセージボックスを表示するか
            //  - false: 表示しない
            //  - true:  表示する
            show_on_bg: false,

            // 選択肢表示中にメッセージボックスを表示するか
            //  - false: 表示しない
            //  - true:  表示する
            show_on_choose: true,

            // 未読メッセージをスキップ対象にするか
            //  - false: スキップしない
            //  - true:  スキップする
            skip_unseen: false,

            // メッセージボックス内ボタンの設定
