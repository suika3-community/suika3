#
# Title GUI
#

# Basic settings for this GUI.
global {
    # Fading-in time in seconds.
    fadein: 0.5;

    # Fading-out time in seconds.
    fadeout: 0.5;

    # Sound effect on cancel.
    cancelse: sound/se/click.ogg;
}

BASE {
    id: 32;
    type: noaction;
    x: 0;
    y: 0;
    image-idle: system/title/base.png;
}

START {
    id: 1;
    type: goto;
    label: start;
    image-idle: system/title/start-idle.png;
    image-hover: system/title/start-hover.png;
    image-press: system/title/start-press.png;
    x: 1110;
    y: 480;
}
