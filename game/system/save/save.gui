#
# Save Menu GUI
#

# Basic settings for this GUI.
global {
    # Fading-in time in seconds.
    fadein: 0.1;

    # Fading-out time in seconds.
    fadeout: 0.2;

    # Cancel on click on margin.
    clickcancel: yes;

    # Cancel on ESC key.
    escapecancel: yes;

    # Sound effect on cancel.
    cancelse: system/save/click.ogg;

    # Save slots per page.
    saveslots: 4;
}

BASE {
    id: 32;
    type: noaction;
    x: 0;
    y: 0;
    image-idle: system/save/save-base.png;
}

