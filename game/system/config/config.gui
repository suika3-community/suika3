PREVIEW {
    id:          6;
    type:        preview;
    x:           720;
    y:           460;
    image-idle:  system/config/config-preview.png;

    msg-en:      "The quick brown fox jumps over the lazy dog.";
    msg-fr:      "On ne voit bien qu'avec le cœur. L'essentiel est invisible pour les yeux.";
    msg-es:      "Caminante, no hay camino, se hace camino al andar.";
    msg-de:      "Verweile doch! Du bist so schön!";
    msg-it:      "Nel mezzo del cammin di nostra vita mi ritrovai per una selva oscura.";
    msg-ru:      "Я помню чудное мгновенье: Передо мной явилась ты...";
    msg-el:      "Ὁ δὲ ἀνεξέταστος βίος οὐ βιωτὸς ἀνθρώπῳ.";
    msg-zh-cn:   "国破山河在，城春草木深。感时花溅泪，恨别鸟惊心。";
    msg-zh-tw:   "國破山河在，城春草木深。感時花濺淚，恨別鳥驚心。";
    msg-ja:      "あのイーハトーヴォのすきとおった風、夏でも底に冷たさをもつ青いそら、うつくしい森で飾られたモリーオ市、郊外のぎらぎらひかる草の波。";
    msg:         "The quick brown fox jumps over the lazy dog.";

    margin-left:   10;
    margin-top:    5;
    margin-right:  10;
    margin-bottom: 5;

}

