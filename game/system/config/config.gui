#
# Config GUI
#

# Basic settings for this GUI.
global {
    # Fading-in time in seconds.
    fadein: 0.2;

    # Fading-out time in seconds.
    fadeout: 0.2;

    # Cancel on click on margin.
    clickcancel: yes;

    # Cancel on ESC key.
    escapecancel: yes;

    # Sound effect on cancel.
    cancelse: sound/se/click.ogg;
}

BASE {
    id: 32;
    type: noaction;
    x: 0;
    y: 0;
    image-idle: system/config/config-base.png;
}

