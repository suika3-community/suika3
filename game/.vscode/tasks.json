{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Suika3: Run",
      "type": "shell",
      "problemMatcher": {
        "owner": "novelml",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^.+: (.+):(\\d+):\\s*(.+)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      },
      "command": "suika3",
      "windows": {
        "command": "SDK/windows/suika3-debug.exe"
      },
      "osx": {
        "command": "sh SDK/macos/suika3-wrapper.sh suika3"
      },
      "linux": {
        "command": "sh SDK/linux/suika3-wrapper.sh suika3"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Suika3: Create a package file",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-Command",
          "& { $files = Get-ChildItem -Path . -Exclude 'SDK', '.vscode', 'suika3.exe', 'save', 'assets.arc' | Select-Object -ExpandProperty Name; SDK/windows/suika3-pack.exe $files }"
        ]
      },
      "osx": {
        "command": "sh SDK/macos/suika3-wrapper.sh suika3-pack"
      },
      "linux": {
        "command": "sh SDK/linux/suika3-wrapper.sh suika3-pack"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Suika3: Build iOS IPA",
      "type": "shell",
      "windows": {
        "command": "echo Not supported on Windows."
      },
      "linux": {
        "command": "echo Not supported on Linux."
      },
      "osx": {
        "command": "sh ${workspaceFolder}/SDK/ios/build.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Suika3: Build Android APK",
      "type": "shell",
      "windows": {
        "command": "${workspaceFolder}/SDK/android/build.bat"
      },
      "linux": {
        "command": "sh ${workspaceFolder}/SDK/android/build.sh"
      },
      "osx": {
        "command": "sh ${workspaceFolder}/SDK/android/build.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}/SDK/android"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
